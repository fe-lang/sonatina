#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: false, evm_trace: false, opt: 1 }
#! evm.case: ok
#!   calldata: u256(5) u256(7)
#!   expect: return u256(19)

target = "evm-ethereum-osaka"

type @slice = { i256, i256 };

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i256 = evm_calldata_load 32.i32;
        v2.i256 = call %agg v0 v1;
        v3.i256 = call %agg_phi v0 v1;
        v4.i256 = add v2 v3;
        mstore 0.i32 v4 i256;
        evm_return 0.i8 32.i8;
}

func private %agg(v0.i256, v1.i256) -> i256 {
    block0:
        v2.@slice = insert_value undef.@slice 0.i8 v0;
        v3.@slice = insert_value v2 1.i8 v1;
        v4.*@slice = alloca @slice;
        mstore v4 v3 @slice;
        v5.@slice = mload v4 @slice;
        v6.i256 = extract_value v5 0.i8;
        v7.i256 = extract_value v5 1.i8;
        v8.i256 = add v6 v7;
        return v8;
}

func private %agg_phi(v0.i256, v1.i256) -> i256 {
    block0:
        v2.i1 = eq v0 0.i256;
        br v2 block1 block2;

    block1:
        v3.@slice = insert_value undef.@slice 0.i8 v0;
        v4.@slice = insert_value v3 1.i8 v1;
        jump block3;

    block2:
        v5.@slice = insert_value undef.@slice 0.i8 v1;
        v6.@slice = insert_value v5 1.i8 v0;
        jump block3;

    block3:
        v7.@slice = phi (v4 block1) (v6 block2);
        v8.i256 = extract_value v7 0.i8;
        return v8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
