#! evm.case: ok
#!   calldata: u32be(11) u32be(22)
#!   expect: return u256(484)

target = "evm-ethereum-osaka"

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i256 = shr 248.i256 v0;
        v2.i256 = shl 32.i256 v0;
        v3.i256 = shr 224.i256 v2;
        v4.i256 = call %main v1 v3;

        mstore 0.i256 v4 i256;
        evm_return 0.i256 32.i256;
}

func private %square(v0.i256) -> i256 {
    block0:
        v1.i256 = mul v0 v0;
        return v1;
}

func private %invert(v0.i256) -> i256 {
    block0:
        v1.i256 = mul v0 -1.i256;
        return v1;
}

func public %main(v0.i256, v1.i256) -> i256 {
    block0:
        br_table v0 block3 (0.i256 block1) (1.i256 block2);

    block1:
        v2.i256 = call %square v1;
        jump block4;

    block2:
        v3.i256 = call %invert v1;
        jump block4;

    block3:
        jump block4;

    block4:
        v4.i256 = phi (v2 block1) (v3 block2) (v0 block3);
        return v4;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
