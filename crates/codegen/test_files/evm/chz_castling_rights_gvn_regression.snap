// func private %meta_custom(v0.i256, v1.i256, v2.i256, v3.i256, v4.i256, v5.i256, v6.i256) -> i256
meta_custom:
  block0:
    JUMPDEST
    PUSH1 block4  // br v0 block4 block2;
    JUMPI
  block2:
    PUSH0  // jump block3;
    PUSH1 block3
    JUMP
  block4:
    JUMPDEST
    PUSH1 0x1 (1)  // jump block3;
  block3:
    JUMPDEST
    SWAP1  // v9.i256 = and v1 v8;
    PUSH1 0xf (15)
    AND
    PUSH1 0x1 (1)  // v11.i256 = shl v10 v9;
    SHL
    OR  // v12.i256 = or v7 v11;
    SWAP1  // v13.i256 = and v2 v8;
    PUSH1 0xf (15)
    AND
    PUSH1 0x5 (5)  // v15.i256 = shl v14 v13;
    SHL
    OR  // v16.i256 = or v12 v15;
    SWAP1  // v18.i256 = and v3 v17;
    PUSH1 0xff (255)
    AND
    PUSH1 0x9 (9)  // v20.i256 = shl v19 v18;
    SHL
    OR  // v22.i256 = or v16 v20;
    SWAP1  // v24.i256 = shl v23 v4;
    PUSH1 0x11 (17)
    SHL
    OR  // v25.i256 = or v22 v24;
    SWAP1  // v27.i256 = and v5 v26;
    PUSH1 0x3f (63)
    AND
    PUSH1 0x21 (33)  // v29.i256 = shl v28 v27;
    SHL
    OR  // v30.i256 = or v25 v29;
    SWAP1  // v31.i256 = and v6 v26;
    PUSH1 0x3f (63)
    AND
    PUSH1 0x27 (39)  // v33.i256 = shl v32 v31;
    SHL
    OR  // v34.i256 = or v30 v33;
    SWAP1  // return v34;
    JUMP

