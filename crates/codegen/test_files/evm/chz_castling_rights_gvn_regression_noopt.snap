    PUSH2 0x4e0 (1248)  // v4.i256 = evm_mload v2;
    MLOAD
    PUSH5 0x7e00000000 (541165879296)  // v10.i256 = and v4 v9;
    NOT
    AND
    PUSH2 0x500 (1280)  // v11.i256 = evm_mload v3;
    MLOAD
    PUSH1 0xff (255)  // v13.i256 = and v11 v12;
    AND
    PUSH1 0x3f (63)  // v13.i256 = and v13 63.i256;
    AND
    PUSH1 0x21 (33)  // v15.i256 = shl 33.i256 v13;
    SHL
    OR  // v16.i256 = or v10 v15;
    SWAP1  // return v16;
    JUMP

// func private %meta_fullmove_number(v0.i256) -> i256
meta_fullmove_number:
  block0:
