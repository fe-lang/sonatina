    AND
    PUSH1 `pc + (4)`  // v7.i256 = call %downcast_truncate__gaa7e v6;
    SWAP1
    PUSH1 FuncRef(6)
    JUMP
    JUMPDEST
    SWAP1  // return v7;
    JUMP

