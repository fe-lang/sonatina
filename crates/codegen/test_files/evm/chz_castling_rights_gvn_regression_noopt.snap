    PUSH1 0x9 (9)  // v15.i256 = shl 9.i256 v13;
    SHL
    OR  // v16.i256 = or v10 v15;
    SWAP1  // return v16;
    JUMP

// func private %meta_set_side_to_move(v0.i256, v1.i1) -> i256
meta_set_side_to_move:
  block0:
    JUMPDEST
    PUSH2 0x4e0 (1248)  // evm_mstore v3 v0;
    MSTORE
    PUSH2 0x500 (1280)  // evm_mstore v4 v1;
    MSTORE
    PUSH2 0x500 (1280)  // v7.i256 = evm_mload v4;
    MLOAD
    PUSH1 0x1 (1)  // v10.i256 = and v7 v8;
    AND
    ISZERO  // v16.i1 = is_zero v10;
    PUSH1 block4  // br v16 block4 block2;
    JUMPI
  block2:
    PUSH1 0x1 (1)  // jump block3;
    PUSH1 block3
    JUMP
  block4:
    JUMPDEST
    PUSH0  // jump block3;
  block3:
    JUMPDEST
    PUSH2 0x4e0 (1248)  // v11.i256 = evm_mload v3;
    MLOAD
    PUSH1 0x1 (1)  // v13.i256 = and v11 -2.i256;
    NOT
    AND
    OR  // v15.i256 = or v13 v2;
    SWAP1  // return v15;
    JUMP

