#! evm.config: { vcode: true, emit_observability: true }
#! evm.case: index_2
#!   calldata: u256(2)
#!   expect: return u256(400)

target = "evm-ethereum-osaka"

global private const [i16; 4] $halves = [100, 200, 400, 800];

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i16 = call %load_half v0;
        v2.i256 = zext v1 i256;
        mstore 0.i32 v2 i256;
        evm_return 0.i8 32.i8;
}

func private %load_half(v0.i256) -> i16 {
    block0:
        v1.constref<[i16; 4]> = const.ref $halves;
        v2.constref<i16> = const.index v1 v0;
        v3.i16 = const.load v2;
        return v3;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
