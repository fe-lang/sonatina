#! evm.config: { vcode: true, emit_observability: true }
#! evm.case: index_2
#!   calldata: u256(2)
#!   expect: return u256(42)

target = "evm-ethereum-osaka"

global private const [i64; 4] $words = [11, 99, 42, 77];

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i64 = call %load_word v0;
        v2.i256 = zext v1 i256;
        mstore 0.i32 v2 i256;
        evm_return 0.i8 32.i8;
}

func private %load_word(v0.i256) -> i64 {
    block0:
        v1.constref<[i64; 4]> = const.ref $words;
        v2.constref<i64> = const.index v1 v0;
        v3.i64 = const.load v2;
        return v3;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
