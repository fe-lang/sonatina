#! evm.config: { vcode: true, emit_observability: true }
#! evm.case: index_4
#!   calldata: u256(4)
#!   expect: return u256(13)

target = "evm-ethereum-osaka"

global private const [i256; 6] $periodic = [5, 13, 9, 5, 13, 9];

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i256 = call %load_periodic v0;
        mstore 0.i32 v1 i256;
        evm_return 0.i8 32.i8;
}

func private %load_periodic(v0.i256) -> i256 {
    block0:
        v1.constref<[i256; 6]> = const.ref $periodic;
        v2.constref<i256> = const.index v1 v0;
        v3.i256 = const.load v2;
        return v3;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
