#! evm.config: { vcode: true, emit_observability: true }
#! evm.case: index_2
#!   calldata: u256(2)
#!   expect: return u256(8)

target = "evm-ethereum-osaka"

type @five = { i256, i256, i256, i256, i256 };

global private const [i256; 5] $arr = [1, 3, 7, 15, 31];
global private const @five $row = {1, 3, 7, 15, 31};

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i256 = call %load_arr v0;
        v2.constref<@five> = call %addr_row;
        v3.constref<i256> = const.proj v2 0.i8;
        v4.i256 = const.load v3;
        v5.i256 = add v1 v4;
        mstore 0.i32 v5 i256;
        evm_return 0.i8 32.i8;
}

func private %load_arr(v0.i256) -> i256 {
    block0:
        v1.constref<[i256; 5]> = const.ref $arr;
        v2.constref<i256> = const.index v1 v0;
        v3.i256 = const.load v2;
        return v3;
}

func private %addr_row() -> constref<@five> {
    block0:
        v0.constref<@five> = const.ref $row;
        return v0;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
