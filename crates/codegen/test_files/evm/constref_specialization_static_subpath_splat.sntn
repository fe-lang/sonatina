#! evm.config: { vcode: true, emit_observability: true }
#! evm.case: index_0
#!   calldata: u256(0)
#!   expect: return u256(7)
#! evm.case: index_1
#!   calldata: u256(1)
#!   expect: return u256(7)

target = "evm-ethereum-osaka"

global private const [[i256; 2]; 2] $rows = [[1, 2], [7, 7]];

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.constref<[[i256; 2]; 2]> = const.ref $rows;
        v2.constref<[i256; 2]> = const.index v1 1.i8;
        v3.i256 = call %load v2 v0;
        mstore 0.i32 v3 i256;
        evm_return 0.i8 32.i8;
}

func private %load(v0.constref<[i256; 2]>, v1.i256) -> i256 {
    block0:
        v2.constref<i256> = const.index v0 v1;
        v3.i256 = const.load v2;
        return v3;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
