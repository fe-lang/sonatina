#! evm.config: { vcode: true }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(60)

target = "evm-ethereum-osaka"

func public %f(v0.i1) -> i256 {
block0:
    v1.*i256 = alloca i256;
    mstore v1 10.i256 i256;
    v2.*i256 = alloca i256;
    mstore v2 20.i256 i256;
    br v0 block1 block2;

block1:
    v3.*i8 = evm_malloc 32.i256;
    v4.*i256 = bitcast v3 *i256;
    mstore v4 999.i256 i256;
    v5.i256 = call %f 0.i1;
    v6.i256 = mload v1 i256;
    v7.i256 = mload v2 i256;
    v8.i256 = add v5 v6;
    v9.i256 = add v8 v7;
    return v9;

block2:
    v10.i256 = mload v1 i256;
    v11.i256 = mload v2 i256;
    v12.i256 = add v10 v11;
    return v12;
}

func public %entry() {
block0:
    v0.i256 = call %f 1.i1;
    mstore 0.i32 v0 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
