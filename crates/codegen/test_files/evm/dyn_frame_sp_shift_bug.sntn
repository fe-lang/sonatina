#! evm.config: { vcode: true }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(2)

target = "evm-ethereum-osaka"

func public %f(v0.i1) -> i256 {
block0:
    v1.*i256 = alloca i256;
    mstore v1 1.i256 i256;
    br v0 block1 block2;

block1:
    v2.*i8 = evm_malloc 32.i256;
    v3.*i256 = bitcast v2 *i256;
    mstore v3 999.i256 i256;
    v4.i256 = call %f 0.i1;
    v5.i256 = mload v1 i256;
    v6.i256 = add v4 v5;
    return v6;

block2:
    v7.i256 = mload v1 i256;
    return v7;
}

func public %entry() {
block0:
    v0.i256 = call %f 1.i1;
    mstore 0.i32 v0 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
