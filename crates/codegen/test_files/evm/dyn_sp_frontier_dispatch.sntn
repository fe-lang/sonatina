#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: false, evm_trace: false }
#! evm.case: cold
#!   calldata: u32be(1)
#!   expect: return u256(111)
#! evm.case: hot
#!   calldata: u32be(0)
#!   expect: return u256(8)

target = "evm-ethereum-osaka"

func public %ready(v0.i256) -> i256 {
block0:
    v1.i1 = eq v0 0.i256;
    br v1 block1 block2;

block1:
    return 7.i256;

block2:
    v2.*i256 = alloca i256;
    mstore v2 v0 i256;
    v3.i256 = sub v0 1.i256;
    v4.i256 = call %ready v3;
    v5.i256 = mload v2 i256;
    v6.i256 = add v4 v5;
    return v6;
}

func public %dispatch(v0.i1) -> i256 {
block0:
    br v0 block1 block2;

block1:
    v1.*i8 = evm_malloc 32.i256;
    v2.*i256 = bitcast v1 *i256;
    mstore v2 111.i256 i256;
    v3.i256 = mload v2 i256;
    return v3;

block2:
    v4.i256 = call %ready 1.i256;
    return v4;
}

func public %entry() {
block0:
    v0.i256 = evm_calldata_load 0.i32;
    v1.i256 = shr 224.i256 v0;
    v2.i1 = ne v1 0.i256;
    v3.i256 = call %dispatch v2;
    mstore 0.i32 v3 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
