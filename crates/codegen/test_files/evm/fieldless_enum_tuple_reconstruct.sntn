#! evm.config: { opt: 2 }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(0)

target = "evm-ethereum-osaka"

type @E = enum {
    #A,
    #B,
};

type @Pair = { i256, @E };

func private %pair(v0.i1) -> @Pair {
block0:
    br v0 block1 block2;

block1:
    v1.@E = enum.make @E #A;
    v2.@Pair = insert_value undef.@Pair 0.i8 0.i256;
    v3.@Pair = insert_value v2 1.i8 v1;
    return v3;

block2:
    v4.@E = enum.make @E #B;
    v5.@Pair = insert_value undef.@Pair 0.i8 1.i256;
    v6.@Pair = insert_value v5 1.i8 v4;
    return v6;
}

func public %main() -> i256 {
block0:
    v0.@Pair = call %pair 1.i1;
    v1.i256 = extract_value v0 0.i8;
    return v1;
}

func public %entry() {
block0:
    v0.i256 = call %main;
    mstore 0.i8 v0 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
    section runtime {
        entry %entry;
    }
}
