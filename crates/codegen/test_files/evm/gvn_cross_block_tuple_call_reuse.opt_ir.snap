target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func public %entry() {
    block0:
        v0.*i8 = evm_malloc 32.i256;
        v1.*i256 = bitcast v0 *i256;
        mstore v1 99.i256 i256;
        v2.i256 = evm_calldata_load 0.i32;
        v3.i256 = and v2 1.i256;
        v4.i1 = eq v3 0.i256;
        br v4 block1 block8;

    block1:
        (v5.i256, v6.i1) = uaddo v2 1.i256;
        br v6 block9 block2;

    block2:
        v7.i1 = eq v5 5.i256;
        br v7 block4 block8;

    block4:
        v10.*@pair = call %helper v1 0.i256 v5;
        v11.*i256 = bitcast v10 *i256;
        v12.i256 = mload v11 i256;
        v13.i1 = eq v12 1.i256;
        br v13 block5 block8;

    block5:
        v14.*i256 = gep v10 0.i256 1.i256;
        v15.i256 = mload v14 i256;
        mstore 0.i256 v15 i256;
        evm_return 0.i256 32.i256;

    block8:
        mstore 0.i256 0.i256 i256;
        evm_return 0.i256 32.i256;

    block9:
        evm_revert 0.i256 0.i256;
}

func private %helper(v0.*i256, v1.i256, v2.i256) -> *@pair {
    block0:
        v3.i256 = mload v0 i256;
        v27.i1 = eq 5.i256 v2;
        v28.i1 = is_zero v1;
        v29.i1 = and v27 v28;
        v30.i1 = eq 99.i256 v3;
        v8.i1 = and v29 v30;
        br v8 block1 block2;

    block1:
        v9.*i8 = evm_malloc 64.i256;
        v10.*@pair = bitcast v9 *@pair;
        v31.*@pair = bitcast v9 *@pair;
        v11.*i256 = bitcast v31 *i256;
        mstore v11 1.i256 i256;
        v32.*@pair = bitcast v9 *@pair;
        v12.*i256 = gep v32 0.i256 1.i256;
        mstore v12 42.i256 i256;
        return v10;

    block2:
        v13.*i8 = evm_malloc 64.i256;
        v14.*@pair = bitcast v13 *@pair;
        v33.*@pair = bitcast v13 *@pair;
        v15.*i256 = bitcast v33 *i256;
        mstore v15 0.i256 i256;
        v34.*@pair = bitcast v13 *@pair;
        v16.*i256 = gep v34 0.i256 1.i256;
        mstore v16 0.i256 i256;
        return v14;
}


