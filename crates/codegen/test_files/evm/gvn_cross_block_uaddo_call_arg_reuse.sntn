#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: true, evm_trace: false, opt: s }
#! evm.case: ok
#!   calldata: u256(4)
#!   expect: return u256(5)

target = "evm-ethereum-osaka"

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v1.i256 = and v0 1.i256;
        v2.i1 = eq v1 0.i256;
        br v2 block1 block6;

    block1:
        (v3.i256, v4.i1) = uaddo v0 1.i256;
        br v4 block7 block2;

    block2:
        v5.i1 = eq v3 5.i256;
        br v5 block3 block6;

    block3:
        (v6.i256, v7.i1) = uaddo v0 1.i256;
        br v7 block7 block4;

    block4:
        v8.i256 = call %id v6;
        mstore 0.i256 v8 i256;
        evm_return 0.i256 32.i256;

    block6:
        mstore 0.i256 0.i256 i256;
        evm_return 0.i256 32.i256;

    block7:
        evm_revert 0.i256 0.i256;
}

func private %id(v0.i256) -> i256 {
    block0:
        return v0;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
