#! evm.config: { stack_reach: 4, vcode: true, bytecode_hex: false, stackify_trace: true, evm_trace: false, opt: s }
#! evm.case: ok
#!   calldata: u256(4)
#!   expect: return u256(42)

target = "evm-ethereum-osaka"

type @pair = { i256, i256 };

func public %entry() {
    block0:
        v0.*i8 = evm_malloc 32.i256;
        v1.*i256 = bitcast v0 *i256;
        mstore v1 99.i256 i256;

        v2.i256 = evm_calldata_load 0.i32;
        (v3.i256, v4.i1) = uaddo v2 1.i256;
        br v4 block9 block1;

    block1:
        v5.i1 = call %is_ge v3 10.i256;
        br v5 block8 block2;

    block2:
        (v6.i256, v7.i1) = uaddo v2 1.i256;
        br v7 block9 block3;

    block3:
        v8.*@pair = call %helper v1 0.i256 v6;
        v9.*i256 = bitcast v8 *i256;
        v10.i256 = mload v9 i256;
        v11.i1 = eq v10 1.i256;
        br v11 block4 block8;

    block4:
        v12.*i256 = gep v8 0.i256 1.i256;
        v13.i256 = mload v12 i256;
        mstore 0.i256 v13 i256;
        evm_return 0.i256 32.i256;

    block8:
        mstore 0.i256 0.i256 i256;
        evm_return 0.i256 32.i256;

    block9:
        evm_revert 0.i256 0.i256;
}

func private %is_ge(v0.i256, v1.i256) -> i1 {
    block0:
        v2.i1 = lt v0 v1;
        br v2 block1 block2;

    block1:
        return 0.i1;

    block2:
        return 1.i1;
}

func private %helper(v0.*i256, v1.i256, v2.i256) -> *@pair {
    block0:
        v3.i256 = mload v0 i256;
        v4.i1 = eq v1 0.i256;
        v5.i1 = eq v2 5.i256;
        v6.i1 = eq v3 99.i256;
        v7.i1 = and v4 v5;
        v8.i1 = and v7 v6;
        br v8 block1 block2;

    block1:
        v9.*i8 = evm_malloc 64.i256;
        v10.*@pair = bitcast v9 *@pair;
        v11.*i256 = bitcast v10 *i256;
        mstore v11 1.i256 i256;
        v12.*i256 = gep v10 0.i256 1.i256;
        mstore v12 42.i256 i256;
        return v10;

    block2:
        v13.*i8 = evm_malloc 64.i256;
        v14.*@pair = bitcast v13 *@pair;
        v15.*i256 = bitcast v14 *i256;
        mstore v15 0.i256 i256;
        v16.*i256 = gep v14 0.i256 1.i256;
        mstore v16 0.i256 i256;
        return v14;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
