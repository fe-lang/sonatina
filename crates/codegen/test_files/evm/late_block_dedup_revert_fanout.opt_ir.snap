---
source: crates/codegen/tests/evm.rs
expression: opt_ir_snapshot
input_file: test_files/evm/late_block_dedup_revert_fanout.sntn
---
target = "evm-ethereum-osaka"

func public %entry() {
    block0:
        v0.i256 = evm_calldata_load 0.i32;
        v6.i1 = is_zero v0;
        br v6 block1 block2;

    block1:
        evm_revert 0.i256 0.i256;

    block2:
        v2.i1 = eq v0 1.i256;
        br v2 block3 block4;

    block3:
        evm_revert 0.i256 0.i256;

    block4:
        evm_revert 0.i256 0.i256;
}


object @Contract {
    section runtime {
        entry %entry;
    }
}
