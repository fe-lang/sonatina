#! evm.config: { vcode: true, opt: 2, stackify_trace: false }
#! evm.case: default
#!   calldata:
#!   expect: revert 0x

target = "evm-ethereum-osaka"

func public %entry() {
block0:
    v0.i256 = evm_calldata_load 0.i32;
    v1.i1 = eq v0 0.i256;
    br v1 block1 block2;

block1:
    evm_revert 0.i256 0.i256;

block2:
    v2.i1 = eq v0 1.i256;
    br v2 block3 block4;

block3:
    evm_revert 0.i256 0.i256;

block4:
    evm_revert 0.i256 0.i256;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
