#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: false, evm_trace: false }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(9)

target = "evm-ethereum-osaka"

func public %f(v0.i1) -> i256 {
block0:
    br v0 block1 block2;

block1:
    return 0.i256;

block2:
    v1.*i256 = alloca i256;
    mstore v1 1.i256 i256;
    v2.i256 = call %f 1.i1;
    v3.i256 = mload v1 i256;
    v4.i256 = add v2 v3;
    return v4;
}

func public %g(v0.i1) -> i256 {
block0:
    br v0 block1 block2;

block1:
    return 0.i256;

block2:
    v1.*i256 = alloca i256;
    mstore v1 7.i256 i256;
    v2.i256 = call %f 0.i1;
    v3.i256 = mload 128.i32 i256;
    v4.i256 = call %f 0.i1;
    v5.i256 = mload 128.i32 i256;
    v6.i256 = call %g 1.i1;
    v7.i256 = add v2 v4;
    v8.i256 = mload v1 i256;
    v9.i1 = eq v3 v5;
    br v9 block3 block4;

block3:
    v10.i256 = add v6 v7;
    v11.i256 = add v10 v8;
    return v11;

block4:
    return 0.i256;
}

func public %entry() {
block0:
    v0.i256 = call %g 0.i1;
    mstore 0.i32 v0 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
