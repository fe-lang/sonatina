#! evm.config: { vcode: true, opt: 2, stackify_trace: false }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(10)

target = "evm-ethereum-osaka"

func private %sum_obj(v0.objref<[i256; 4]>) -> i256 {
    block0:
        jump block1;

    block1:
        v1.i256 = phi (0.i256 block0) (v6 block2);
        v2.i256 = phi (0.i256 block0) (v7 block2);
        v3.i1 = lt v1 4.i256;
        br v3 block2 block3;

    block2:
        v4.objref<i256> = obj.index v0 v1;
        v5.i256 = obj.load v4;
        v7.i256 = add v2 v5;
        v6.i256 = add v1 1.i256;
        jump block1;

    block3:
        return v2;
}

func public %entry() {
    block0:
        v0.objref<[i256; 4]> = obj.alloc [i256; 4];

        v1.objref<i256> = obj.index v0 0.i256;
        obj.store v1 1.i256;

        v2.objref<i256> = obj.index v0 1.i256;
        obj.store v2 2.i256;

        v3.objref<i256> = obj.index v0 2.i256;
        obj.store v3 3.i256;

        v4.objref<i256> = obj.index v0 3.i256;
        obj.store v4 4.i256;

        v5.i256 = call %sum_obj v0;
        mstore 0.i256 v5 i256;
        evm_return 0.i256 32.i256;
}

object @Contract {
    section runtime {
        entry %entry;
    }
}
