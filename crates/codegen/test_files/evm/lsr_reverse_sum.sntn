#! evm.config: { vcode: true, opt: 2, stackify_trace: false }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(26)

target = "evm-ethereum-osaka"

func private %sum_last4(v0.i256) -> i256 {
    block0:
        jump block1;

    block1:
        v1.i256 = phi (0.i256 block0) (v6 block2);
        v2.i256 = phi (0.i256 block0) (v7 block2);
        v3.i1 = lt v1 4.i256;
        br v3 block2 block3;

    block2:
        v4.i256 = sub 7.i256 v1;
        v5.*[i256; 8] = int_to_ptr v0 *[i256; 8];
        v8.*i256 = gep v5 0.i256 v4;
        v9.i256 = mload v8 i256;
        v7.i256 = add v2 v9;
        v6.i256 = add v1 1.i256;
        jump block1;

    block3:
        return v2;
}

func public %entry() {
    block0:
        v0.*i8 = evm_malloc 256.i256;
        v1.*[i256; 8] = bitcast v0 *[i256; 8];

        v2.*i256 = gep v1 0.i256 0.i256;
        mstore v2 1.i256 i256;
        v3.*i256 = gep v1 0.i256 1.i256;
        mstore v3 2.i256 i256;
        v4.*i256 = gep v1 0.i256 2.i256;
        mstore v4 3.i256 i256;
        v5.*i256 = gep v1 0.i256 3.i256;
        mstore v5 4.i256 i256;
        v6.*i256 = gep v1 0.i256 4.i256;
        mstore v6 5.i256 i256;
        v7.*i256 = gep v1 0.i256 5.i256;
        mstore v7 6.i256 i256;
        v8.*i256 = gep v1 0.i256 6.i256;
        mstore v8 7.i256 i256;
        v9.*i256 = gep v1 0.i256 7.i256;
        mstore v9 8.i256 i256;

        v10.i256 = ptr_to_int v0 i256;
        v11.i256 = call %sum_last4 v10;
        mstore 0.i256 v11 i256;
        evm_return 0.i256 32.i256;
}

object @Contract {
    section runtime {
        entry %entry;
    }
}
