#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: false, evm_trace: false }
#! evm.case: ok
#!   calldata: u32be(1)
#!   expect: return u256(116)

target = "evm-ethereum-osaka"

func public %helper() -> i256 {
block0:
    v0.*i8 = evm_malloc 32.i256;
    v1.*i256 = bitcast v0 *i256;
    mstore v1 111.i256 i256;
    v2.i256 = mload v1 i256;
    return v2;
}

func public %ready(v0.i256) -> i256 {
block0:
    v1.i1 = eq v0 0.i256;
    br v1 block1 block2;

block1:
    return 0.i256;

block2:
    v2.*i256 = alloca i256;
    mstore v2 5.i256 i256;
    v3.i256 = call %helper;
    v4.i256 = sub v0 1.i256;
    v5.i256 = call %ready v4;
    v6.i256 = mload v2 i256;
    v7.i256 = add v3 v5;
    v8.i256 = add v7 v6;
    return v8;
}

func public %entry() {
block0:
    v0.i256 = evm_calldata_load 0.i32;
    v1.i256 = shr 224.i256 v0;
    v2.i256 = call %ready v1;
    mstore 0.i32 v2 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
