func private %decode_0(v0.objref<@Decoder>) -> i256 {
block0:
    v1.i256 = call %read_word v0;
    return v1;
}

func private %decode_returndata(v0.i256, v1.i256) -> i256 {
block0:
    v3.i1 = call %lt_0 v1 32.i256;
    br v3 block1 block2;

block1:
    evm_revert 0.i256 0.i256;

block2:
    jump block3;

block3:
    v5.objref<@Bytes> = obj.alloc @Bytes;
    v7.objref<i256> = obj.proj v5 0.i256;
    obj.store v7 v0;
    v10.objref<i256> = obj.proj v5 1.i256;
    obj.store v10 v1;
    v11.@Bytes = obj.load v5;
    v12.@Decoder = call %new_decoder v11;
    v13.objref<@Decoder> = obj.alloc @Decoder;
    obj.store v13 v12;
    v14.i256 = call %decode_0 v13;
    return v14;
}

func private %call_target(v0.@Addr, v1.i256, v2.i256) -> i256 {
block0:
    v3.objref<@Addr> = obj.alloc @Addr;
    v4.objref<@CallData> = obj.alloc @CallData;
    obj.store v3 v0;
    v6.@CallData = call %encode_calldata -810667497.i32;
    obj.store v4 v6;
    v8.objref<i256> = obj.proj v3 0.i256;
    v9.i256 = obj.load v8;
    v10.objref<i256> = obj.proj v4 0.i256;
    v11.i256 = obj.load v10;
    v13.objref<i256> = obj.proj v4 1.i256;
    v14.i256 = obj.load v13;
    v15.i256 = evm_call v1 v9 v2 v11 v14 0.i256 0.i256;
    v16.i256 = evm_return_data_size;
    v17.*i8 = evm_malloc v16;
    v18.i256 = ptr_to_int v17 i256;
    evm_return_data_copy v18 0.i256 v16;
    v20.i1 = call %eq_0 v15 0.i256;
    br v20 block1 block2;

block1:
    evm_revert v18 v16;

block2:
    jump block3;

block3:
    v25.i256 = call %decode_returndata v18 v16;
    return v25;
}

func public %entry() {
block0:
    v0.i256 = evm_calldata_size;
    v1.i1 = eq v0 0.i256;
    br v1 block1 block2;

block1:
    v2.objref<@Addr> = obj.alloc @Addr;
    v3.i256 = evm_address;
    v4.objref<i256> = obj.proj v2 0.i256;
    obj.store v4 v3;
    v5.@Addr = obj.load v2;
    v6.i256 = call %call_target v5 100000.i256 0.i256;
    mstore 0.i32 v6 i256;
    evm_return 0.i8 32.i8;

block2:
    mstore 0.i32 42.i256 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
