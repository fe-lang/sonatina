func private %word_at_0(v0.@Bytes, v1.i256) -> i256 {
block0:
    v2.objref<@Bytes> = obj.alloc @Bytes;
    obj.store v2 v0;
    v4.objref<i256> = obj.proj v2 0.i256;
    v5.i256 = obj.load v4;
    v6.i256 = call %add_1 v5 v1;
    v7.i256 = mload v6 i256;
    return v7;
}

func private %read_word(v0.objref<@Decoder>) -> i256 {
block0:
    v2.objref<@Cursor> = obj.proj v0 0.i256;
    v3.@Cursor = obj.load v2;
    v4.objref<@Cursor> = obj.proj v0 0.i256;
    v5.objref<@Bytes> = obj.proj v4 0.i256;
    v6.@Bytes = obj.load v5;
    v7.i256 = call %len_0 v6;
    v8.objref<@Cursor> = obj.proj v0 0.i256;
    v9.@Cursor = obj.load v8;
    v10.objref<@Cursor> = obj.proj v0 0.i256;
    v12.objref<i256> = obj.proj v10 1.i256;
    v13.i256 = obj.load v12;
    v15.i256 = call %add_1 v13 32.i256;
    v16.i1 = call %gt_0 v15 v7;
    br v16 block1 block2;

block1:
    evm_revert 0.i256 0.i256;

block2:
    jump block3;

block3:
    v18.objref<@Cursor> = obj.proj v0 0.i256;
    v19.@Cursor = obj.load v18;
    v20.objref<@Cursor> = obj.proj v0 0.i256;
    v21.objref<@Bytes> = obj.proj v20 0.i256;
    v22.@Bytes = obj.load v21;
    v23.objref<@Cursor> = obj.proj v0 0.i256;
    v24.@Cursor = obj.load v23;
    v25.objref<@Cursor> = obj.proj v0 0.i256;
    v26.objref<i256> = obj.proj v25 1.i256;
    v27.i256 = obj.load v26;
    v28.i256 = call %word_at_0 v22 v27;
    v30.objref<@Cursor> = obj.proj v0 0.i256;
    v31.objref<i256> = obj.proj v30 1.i256;
    obj.store v31 v15;
