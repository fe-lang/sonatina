#! evm.config: { vcode: true, opt: 2 }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(42)

target = "evm-ethereum-osaka"

type @Addr = { i256 };
type @Bytes = { i256, i256 };
type @Cursor = { @Bytes, i256 };
type @Decoder = { @Cursor, i256 };
type @CallData = { i256, i256 };

func private %add_0(v0.i256, v1.i256) -> i256 {
block0:
    (v2.i256, v3.i1) = uaddo v0 v1;
    br v3 block1 block2;

block1:
    evm_revert 0.i256 0.i256;

block2:
    return v2;
}

func private %add_1(v0.i256, v1.i256) -> i256 {
block0:
    (v2.i256, v3.i1) = uaddo v0 v1;
    br v3 block1 block2;

block1:
    evm_revert 0.i256 0.i256;

block2:
    return v2;
}

func private %eq_0(v0.i256, v1.i256) -> i1 {
block0:
    v2.i1 = eq v0 v1;
    return v2;
}

func private %gt_0(v0.i256, v1.i256) -> i1 {
block0:
    v2.i1 = gt v0 v1;
