func private %encode_to_ptr(v0.i256) {
block0:
    return;
}

func private %encode_calldata(v0.i32) -> @CallData {
block0:
    v2.i256 = zext v0 i256;
    v4.i256 = call %shl_0 v2 224.i256;
    v7.*i8 = evm_malloc 4.i256;
    v8.i256 = ptr_to_int v7 i256;
    mstore v8 v4 i256;
    v12.i256 = call %add_0 v8 4.i256;
    call %encode_to_ptr v12;
    v14.objref<@CallData> = obj.alloc @CallData;
    v15.objref<i256> = obj.proj v14 0.i256;
    obj.store v15 v8;
    v17.objref<i256> = obj.proj v14 1.i256;
    obj.store v17 4.i256;
    v18.@CallData = obj.load v14;
    return v18;
}

func private %new_cursor(v0.@Bytes) -> @Cursor {
block0:
    v2.objref<@Cursor> = obj.alloc @Cursor;
    v3.objref<@Bytes> = obj.proj v2 0.i256;
    obj.store v3 v0;
    v5.objref<i256> = obj.proj v2 1.i256;
    obj.store v5 0.i256;
    v6.@Cursor = obj.load v2;
    return v6;
}

func private %new_decoder(v0.@Bytes) -> @Decoder {
block0:
    v1.@Cursor = call %new_cursor v0;
    v3.objref<@Decoder> = obj.alloc @Decoder;
    v4.objref<@Cursor> = obj.proj v3 0.i256;
    obj.store v4 v1;
    v6.objref<i256> = obj.proj v3 1.i256;
    obj.store v6 0.i256;
    v7.@Decoder = obj.load v3;
    return v7;
}

func private %len_0(v0.@Bytes) -> i256 {
block0:
    v1.objref<@Bytes> = obj.alloc @Bytes;
    obj.store v1 v0;
    v3.objref<i256> = obj.proj v1 1.i256;
    v4.i256 = obj.load v3;
    return v4;
