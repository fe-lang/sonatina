#! evm.config: { vcode: true, opt: 0 }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(30)

target = "evm-ethereum-osaka"

type @Data = { i256, i256 };
type @LiveView = { objref<i256>, objref<i256> };

func private %make_view(v0.objref<@Data>) -> objref<@LiveView> {
block0:
    v1.objref<@LiveView> = obj.alloc @LiveView;
    v2.objref<i256> = obj.proj v0 0.i8;
    v3.objref<objref<i256>> = obj.proj v1 0.i8;
    obj.store v3 v2;
    v4.objref<i256> = obj.proj v0 1.i8;
    v5.objref<objref<i256>> = obj.proj v1 1.i8;
    obj.store v5 v4;
    return v1;
}

func private %read_view(v0.objref<@LiveView>) -> i256 {
block0:
    v1.objref<objref<i256>> = obj.proj v0 0.i8;
    v2.objref<i256> = obj.load v1;
    v3.i256 = obj.load v2;
    v4.objref<objref<i256>> = obj.proj v0 1.i8;
    v5.objref<i256> = obj.load v4;
    v6.i256 = obj.load v5;
    v7.i256 = add v3 v6;
    return v7;
}

func public %entry() {
block0:
    v0.objref<@Data> = obj.alloc @Data;
    v1.objref<i256> = obj.proj v0 0.i8;
    obj.store v1 10.i256;
    v2.objref<i256> = obj.proj v0 1.i8;
    obj.store v2 20.i256;
    v3.objref<@LiveView> = call %make_view v0;
    v4.i256 = call %read_view v3;
    mstore 0.i256 v4 i256;
    evm_return 0.i256 32.i256;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
