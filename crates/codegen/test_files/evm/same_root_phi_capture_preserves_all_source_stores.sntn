#! evm.config: { vcode: true, opt: 2 }
#! evm.case: field0
#!   calldata: u256(0)
#!   expect: return u256(10)
#! evm.case: field1
#!   calldata: u256(1)
#!   expect: return u256(20)

target = "evm-ethereum-osaka"

type @Data = { i256, i256 };
type @Cell = { objref<i256> };

func private %capture(v0.objref<@Cell>, v1.objref<i256>) {
block0:
    v2.objref<objref<i256>> = obj.proj v0 0.i8;
    obj.store v2 v1;
    return;
}

func private %read_cell(v0.objref<@Cell>) -> i256 {
block0:
    v1.objref<objref<i256>> = obj.proj v0 0.i8;
    v2.objref<i256> = obj.load v1;
    v3.i256 = obj.load v2;
    return v3;
}

func private %main(v0.i256) -> i256 {
block0:
    v1.objref<@Data> = obj.alloc @Data;
    v2.objref<i256> = obj.proj v1 0.i8;
    obj.store v2 10.i256;
    v3.objref<i256> = obj.proj v1 1.i8;
    obj.store v3 20.i256;
    v4.objref<@Cell> = obj.alloc @Cell;
    v5.i1 = eq v0 0.i256;
    br v5 block1 block2;

block1:
    v6.objref<i256> = obj.proj v1 0.i8;
    jump block3;

block2:
    v7.objref<i256> = obj.proj v1 1.i8;
    jump block3;

block3:
    v8.objref<i256> = phi (v6 block1) (v7 block2);
    call %capture v4 v8;
    v9.i256 = call %read_cell v4;
    return v9;
}

func public %entry() {
block0:
    v0.i256 = evm_calldata_load 0.i32;
    v1.i256 = call %main v0;
    mstore 0.i32 v1 i256;
    evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
