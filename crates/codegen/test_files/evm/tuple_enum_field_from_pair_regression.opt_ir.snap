    #None,
    #A,
};

func public %entry() {
    block0:
        v1.objref<@Pair> = obj.alloc @Pair;
        v3.objref<[i256; 2]> = obj.proj v1 0.i256;
        v4.objref<i256> = obj.index v3 0.i256;
        obj.store v4 5.i256;
        v7.objref<i256> = obj.index v3 1.i256;
        obj.store v7 9.i256;
        v9.objref<@E> = obj.proj v1 1.i256;
        enum.set_tag v9 #None;
        v10.@Pair = obj.load v1;
        v11.[i256; 2] = extract_value v10 0.i256;
        v12.@E = extract_value v10 1.i256;
        v13.enumtag(@E) = enum.tag v12;
        br_table v13 block4 (0.enumtag(@E) block5) (1.enumtag(@E) block3);

