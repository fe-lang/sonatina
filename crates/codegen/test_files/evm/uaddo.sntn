#! evm.config: { vcode: true, bytecode_hex: false, stackify_trace: false, evm_trace: false }
#! evm.case: ok
#!   calldata:
#!   expect: return u256(1)

target = "evm-ethereum-osaka"

func public %entry() {
    block0:
        (v0.i256, v1.i1) = uaddo 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff.i256 1.i256;
        br v1 block1 block2;

    block1:
        mstore 0.i8 1.i256 i256;
        evm_return 0.i8 32.i8;

    block2:
        mstore 0.i8 v0 i256;
        evm_return 0.i8 32.i8;
}

object @Contract {
  section runtime {
    entry %entry;
  }
}
