    PUSH1 0x1 (1)  // v3.i1 = eq 1.i256 v0;
    EQ
    PUSH1 block5  // br v3 block5 block4;
    JUMPI
  block4:
    PUSH0  // jump block3;
    PUSH1 block3
    JUMP
  block5:
    JUMPDEST
    PUSH1 0x1 (1)  // jump block3;
  block3:
    JUMPDEST
    PUSH0  // mstore 0.i256 v5 i256;
    MSTORE
    PUSH1 0x20 (32)  // evm_return 0.i256 32.i256;
    PUSH0
    RETURN

// func private %leanimt_root_from_calldata(v0.i256, v1.i256, v2.i256, v3.i256) -> i256
leanimt_root_from_calldata:
  block0:
    JUMPDEST
    PUSH1 0x20 (32)  // v6.i1 = gt v2 32.i256;
    DUP4
    GT
    ISZERO  // br v6 block1 block9;
    PUSH1 block9
    JUMPI
  block1:
    PUSH0  // evm_revert 0.i256 0.i256;
    PUSH0
    REVERT
  block9:
    JUMPDEST
    SWAP3  // jump block3;
    SWAP1
    PUSH0
    SWAP3
    SWAP4
  block3:
    JUMPDEST
    DUP5  // v14.i1 = lt v12 v2;
    DUP5
    LT
    ISZERO  // br v14 block4 block5;
    PUSH1 block5
    JUMPI
  block4:
    DUP3  // v18.i256 = evm_calldata_load v39;
    CALLDATALOAD
    SWAP3  // v19.i256 = add 32.i256 v39;
    PUSH1 0x20 (32)
    ADD
    DUP3  // v26.i256 = and 1.i256 v41;
    PUSH1 0x1 (1)
    AND
    PUSH1 0x1 (1)  // v23.i1 = eq v26 1.i256;
    EQ
    SWAP3  // v25.i256 = shr 1.i256 v41;
    PUSH1 0x1 (1)
    SHR
    SWAP3  // br v23 block6 block8;
    ISZERO
    PUSH1 block8
    JUMPI
  block6:
    SWAP3  // mstore 0.i256 v18 i256;
    PUSH0
    MSTORE
    PUSH1 0x20 (32)  // mstore 32.i256 v43 i256;
    MSTORE
    PUSH1 0x40 (64)  // v53.i256 = evm_keccak256 0.i256 64.i256;
    PUSH0
    KECCAK256
    PUSH1 block7  // jump block7;
    JUMP
  block8:
    JUMPDEST
    SWAP1  // mstore 0.i256 v43 i256;
    PUSH0
    MSTORE
    SWAP2  // mstore 32.i256 v18 i256;
    PUSH1 0x20 (32)
    MSTORE
    PUSH1 0x40 (64)  // v55.i256 = evm_keccak256 0.i256 64.i256;
    PUSH0
    KECCAK256
  block7:
    JUMPDEST
    SWAP3  // v33.i256 = add 1.i256 v12;
    PUSH1 0x1 (1)
    ADD
    SWAP3  // jump block3;
    PUSH1 block3
    JUMP
  block5:
    JUMPDEST
    SWAP4  // return v43;
    POP
    POP
    POP
    POP
    SWAP1
    JUMP

// func private %smt_root_from_calldata(v0.i256, v1.i256, v2.i256, v3.i256) -> i256
smt_root_from_calldata:
  block0:
    JUMPDEST
    DUP3  // v6.i1 = eq 4294967295.i256 v2;
    PUSH4 0xffffffff (4294967295)
    EQ
    PUSH1 block18  // br v6 block18 block2;
    JUMPI
  block2:
    PUSH1 `pc + (3)`  // call %smt_store_zero_table;
    PUSH1 FuncRef(0)
    JUMP
    JUMPDEST
    PUSH0  // jump block9;
    SWAP4
    PUSH1 0x40 (64)
    SWAP3
  block9:
    JUMPDEST
    PUSH1 0x20 (32)  // v40.i1 = lt v39 32.i256;
    DUP7
    LT
    ISZERO  // br v40 block10 block11;
    PUSH1 block11
    JUMPI
  block10:
    DUP5  // v53.i256 = and 1.i256 v86;
    PUSH1 0x1 (1)
    AND
    PUSH1 0x1 (1)  // v45.i1 = eq v53 1.i256;
    EQ
    SWAP5  // v47.i256 = shr 1.i256 v86;
    PUSH1 0x1 (1)
    SHR
    DUP5  // v49.i256 = mload v88 i256;
    MLOAD
    SWAP5  // v50.i256 = add 32.i256 v88;
