// func private %abi_return_bool(v0.i256)
abi_return_bool:
  block0:
    JUMPDEST
    PUSH1 0x1 (1)  // v3.i1 = eq 1.i256 v0;
    EQ
    PUSH1 block6  // br v3 block6 block4;
    JUMPI
  block4:
    PUSH0  // jump block3;
    PUSH1 block3
    JUMP
  block6:
    JUMPDEST
    PUSH1 0x1 (1)  // jump block3;
  block3:
    JUMPDEST
    PUSH0  // mstore 0.i256 v5 i256;
    MSTORE
    PUSH1 0x20 (32)  // evm_return 0.i256 32.i256;
    PUSH0
    RETURN

// func private %leanimt_root_from_calldata(v0.i256, v1.i256, v2.i256, v3.i256) -> i256
leanimt_root_from_calldata:
  block0:
    JUMPDEST
    PUSH1 0x20 (32)  // v6.i1 = gt v2 32.i256;
    DUP4
    GT
    ISZERO  // br v6 block1 block10;
    PUSH1 block10
    JUMPI
  block1:
    PUSH0  // evm_revert 0.i256 0.i256;
    PUSH0
    REVERT
  block10:
    JUMPDEST
    SWAP3  // jump block3;
    SWAP1
    PUSH0
    SWAP3
    SWAP4
  block3:
    JUMPDEST
    DUP5  // v14.i1 = lt v12 v2;
    DUP5
    LT
    ISZERO  // br v14 block4 block5;
    PUSH1 block5
    JUMPI
  block4:
    DUP3  // v18.i256 = evm_calldata_load v39;
    CALLDATALOAD
    SWAP3  // v19.i256 = add 32.i256 v39;
    PUSH1 0x20 (32)
    ADD
    DUP3  // v26.i256 = and 1.i256 v41;
    PUSH1 0x1 (1)
    AND
    PUSH1 0x1 (1)  // v23.i1 = eq v26 1.i256;
    EQ
    SWAP3  // v25.i256 = shr 1.i256 v41;
    PUSH1 0x1 (1)
    SHR
