// func public %hash2_at(v0.i256, v1.i256, v2.i256) -> i256
hash2_at:
  block0:
    JUMPDEST
    SWAP1  // mstore v0 v1 i256;
    DUP2
    MSTORE
    DUP1  // v5.i256 = add 32.i256 v0;
    PUSH1 0x20 (32)
    ADD
    SWAP1  // mstore v5 v2 i256;
    SWAP2
    SWAP1
    MSTORE
    PUSH1 0x40 (64)  // v7.i256 = evm_keccak256 v0 64.i256;
    SWAP1
    KECCAK256
    SWAP1  // return v7;
    JUMP

// func public %hash2(v0.i256, v1.i256) -> i256
hash2:
  block0:
    JUMPDEST
    PUSH1 0x40 (64)  // v4.*i256 = evm_malloc 64.i256;
    MLOAD
    PUSH1 0xbf (191)
    DUP2
    GT
    PUSH1 `pc + (4)`
    JUMPI
    POP
    PUSH1 0xc0 (192)
    JUMPDEST
    SWAP1  // mstore v5 v0 i256;
    DUP2
    MSTORE
    DUP1  // v8.i256 = add 32.i256 v5;
    PUSH1 0x20 (32)
    ADD
    SWAP1  // mstore v8 v1 i256;
    SWAP2
    SWAP1
    MSTORE
    PUSH1 0x40 (64)  // v9.i256 = evm_keccak256 v5 64.i256;
    SWAP1
    KECCAK256
    SWAP1  // return v9;
    JUMP
