target = "evm-ethereum-london"

func public %sum_to(v0.i32) -> i32 {
    block0:
        v1.i1 = eq v0 0.i32;
        br v1 block1 block2;

    block1:
        return 0.i32;

    block2:
        v2.i32 = sub v0 1.i32;
        v3.i32 = call %sum_to v2;
        v4.i32 = add v0 v3;
        return v4;
}
