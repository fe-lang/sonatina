func private %loop(v0.i1, v1.i32) -> i32 {
    block0:
        jump block1;

    block1:
        v2.i32 = phi (v1 block0) (v3 block2);
        br v0 block2 block3;

    block2:
        v3.i32 = add v2 1.i32;
        jump block1;

    block3:
        return v2;
}


func public %caller(v0.i32) -> i32 {
    block0:
        jump block2;

    block2:
        jump block3;

    block3:
        v4.i32 = phi (v0 block2) (v6 block4);
        br 0.i1 block4 block5;

    block4:
        v6.i32 = add v4 1.i32;
        jump block3;

    block5:
        jump block1;

    block1:
        return v4;
}
