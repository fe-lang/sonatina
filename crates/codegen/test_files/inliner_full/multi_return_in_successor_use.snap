func private %pick(v0.i1) -> i32 {
    block0:
        br v0 block1 block2;

    block1:
        return 1.i32;

    block2:
        return 2.i32;
}


func public %caller(v0.i1) -> i32 {
    block0:
        jump block3;

    block3:
        br v0 block4 block5;

    block4:
        jump block2;

    block5:
        jump block2;

    block2:
        v7.i32 = phi (1.i32 block4) (2.i32 block5);
        v2.i32 = add v7 5.i32;
        jump block1;

    block1:
        v3.i32 = mul v2 2.i32;
        return v3;
}
