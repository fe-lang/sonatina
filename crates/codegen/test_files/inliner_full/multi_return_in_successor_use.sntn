target = "evm-ethereum-london"

func private %pick(v0.i1) -> i32 {
    block0:
        br v0 block1 block2;

    block1:
        return 1.i32;

    block2:
        return 2.i32;
}

func public %caller(v0.i1) -> i32 {
    block0:
        v1.i32 = call %pick v0;
        v2.i32 = add v1 5.i32;
        jump block1;

    block1:
        v3.i32 = mul v2 2.i32;
        return v3;
}
