target = "evm-ethereum-osaka"

type @pair = { i256, i256 };

func private %identity(v0.objref<@pair>) -> objref<@pair> {
block0:
    return v0;
}

func private %touch_pair(v0.objref<@pair>, v1.objref<@pair>) {
block0:
    v2.objref<@pair> = call %identity v1;
    return;
}

func private %make_pair(v0.i256, v1.i256) -> objref<@pair> {
block0:
    v2.objref<@pair> = obj.alloc @pair;
    call %touch_pair v2 v2;
    v3.objref<i256> = obj.proj v2 0.i8;
    obj.store v3 v0;
    v4.objref<i256> = obj.proj v2 1.i8;
    obj.store v4 v1;
    return v2;
}
