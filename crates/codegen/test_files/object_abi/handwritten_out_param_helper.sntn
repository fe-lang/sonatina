target = "evm-ethereum-osaka"

type @pair = { i256, i256 };

func private %init_pair(v0.objref<@pair>, v1.i256, v2.i256) {
block0:
    v3.objref<i256> = obj.proj v0 0.i8;
    obj.store v3 v1;
    v4.objref<i256> = obj.proj v0 1.i8;
    obj.store v4 v2;
    return;
}

func private %forward_pair(v0.i256, v1.i256) -> objref<@pair> {
block0:
    v2.objref<@pair> = obj.alloc @pair;
    call %init_pair v2 v0 v1;
    return v2;
}
