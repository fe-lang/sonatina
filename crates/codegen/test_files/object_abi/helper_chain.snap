---
source: crates/codegen/tests/object_abi.rs
input_file: test_files/object_abi/helper_chain.sntn
---
target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %make_pair(v7.objref<@pair>, v0.i256, v1.i256) {
    block0:
        v3.objref<i256> = obj.proj v7 0.i8;
        obj.store v3 v0;
        v4.objref<i256> = obj.proj v7 1.i8;
        obj.store v4 v1;
        return;
}

func private %forward_pair(v3.objref<@pair>, v0.i256, v1.i256) {
    block0:
        call %make_pair v3 v0 v1;
        return;
}

func private %sum_pair(v0.objref<@pair>) -> i256 {
    block0:
        v1.objref<i256> = obj.proj v0 0.i8;
        v2.i256 = obj.load v1;
        v3.objref<i256> = obj.proj v0 1.i8;
        v4.i256 = obj.load v3;
        v5.i256 = add v2 v4;
        return v5;
}

func public %entry(v0.i256, v1.i256) -> i256 {
    block0:
        v4.objref<@pair> = obj.alloc @pair;
        call %forward_pair v4 v0 v1;
        v3.i256 = call %sum_pair v4;
        return v3;
}


object @Contract {
    section runtime {
        entry %entry;
    }
}
