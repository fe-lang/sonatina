---
source: crates/codegen/tests/object_abi.rs
input_file: test_files/object_abi/loop_return_root_not_rewritten.sntn
---
target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %loop_pair(v0.i1, v1.i256) -> objref<@pair> {
    block0:
        jump block1;

    block1:
        v2.objref<@pair> = obj.alloc @pair;
        v3.objref<i256> = obj.proj v2 0.i8;
        obj.store v3 v1;
        br v0 block1 block2;

    block2:
        return v2;
}
