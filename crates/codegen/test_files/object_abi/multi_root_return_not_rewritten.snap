target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %pick_pair(v0.i1) -> objref<@pair> {
    block0:
        br v0 block1 block2;

    block1:
        v1.objref<@pair> = obj.alloc @pair;
        return v1;

    block2:
        v2.objref<@pair> = obj.alloc @pair;
        return v2;
}
