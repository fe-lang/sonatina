target = "evm-ethereum-osaka"

type @option_i256 = enum {
    #None,
    #Some(i256),
};

func private %entry(v0.i256) -> i256 {
block0:
    v1.objref<@option_i256> = obj.alloc @option_i256;
    enum.write_variant v1 #Some (v0);
    enum.assert_variant_ref v1 #Some;
    v2.objref<i256> = enum.proj v1 #Some 0.i8;
    v3.i256 = obj.load v2;
    return v3;
}
