---
source: crates/codegen/tests/object_load_store.rs
input_file: test_files/object_load_store/loop_dynamic_store_to_returned_object_stays_live.sntn
---
target = "evm-ethereum-osaka"

func private %f() -> objref<[i256; 3]> {
    block0:
        v0.objref<[i256; 3]> = obj.alloc [i256; 3];
        jump block1;

    block1:
        v1.i256 = phi (0.i256 block0) (v4 block2);
        v2.i1 = lt v1 3.i256;
        br v2 block2 block3;

    block2:
        v3.objref<i256> = obj.index v0 v1;
        obj.store v3 7.i256;
        v4.i256 = add v1 1.i256;
        jump block1;

    block3:
        return v0;
}
