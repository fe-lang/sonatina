target = "evm-ethereum-osaka"

func private %f(v0.i1) -> objref<[i256; 1]> {
    block0:
        v1.objref<[i256; 1]> = obj.alloc [i256; 1];
        v2.objref<i256> = obj.index v1 0.i256;
        obj.store v2 1.i256;
        v3.objref<[i256; 1]> = obj.alloc [i256; 1];
        v4.objref<i256> = obj.index v3 0.i256;
        obj.store v4 2.i256;
        br v0 block1 block2;

    block1:
        jump block3;

    block2:
        jump block3;

    block3:
        v5.objref<[i256; 1]> = phi (v1 block1) (v3 block2);
        return v5;
}
