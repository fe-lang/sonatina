target = "evm-ethereum-osaka"

type @pair = { i256, i256 };

func private %f(v0.i1, v1.i256) -> i256 {
block0:
    v2.objref<@pair> = obj.alloc @pair;
    br v0 block1 block2;

block1:
    jump block3;

block2:
    jump block3;

block3:
    v3.objref<@pair> = phi (v2 block1) (v2 block2);
    v4.objref<i256> = obj.proj v3 0.i8;
    obj.store v4 v1;
    v5.i256 = obj.load v4;
    return v5;
}
