target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %identity(v0.*@pair) -> *@pair {
    block0:
        return v0;
}

func private %touch_pair(v0.*@pair, v1.*@pair) {
    block0:
        v2.*@pair = call %identity v1;
        return;
}

func private %driver() {
    block0:
        v0.*@pair = alloca @pair;
        call %touch_pair v0 v0;
        return;
}
