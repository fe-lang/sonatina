target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %sink(v0.*@pair) -> i256 {
    block0:
        v1.*i256 = gep v0 0.i64 0.i8;
        v2.i256 = mload v1 i256;
        return v2;
}

func private %sum_materialized(v0.i256, v1.i256) -> i256 {
    block0:
        v2.objref<@pair> = obj.alloc @pair;
        v3.objref<i256> = obj.proj v2 0.i8;
        obj.store v3 v0;
        v4.objref<i256> = obj.proj v2 1.i8;
        obj.store v4 v1;
        v5.*@pair = obj.materialize.stack v2;
        v6.i256 = call %sink v5;
        return v6;
}
