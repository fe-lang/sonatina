type @pair = {i256, i256};
type @wrapper = {*@pair};

func private %sum_wrapper(v0.@wrapper) -> i256 {
    block0:
        v1.*@pair = extract_value v0 0.i8;
        v2.*i256 = gep v1 0.i64 0.i8;
        v3.i256 = mload v2 i256;
        return v3;
}
