target = "evm-ethereum-osaka"

type @pair = {i256, i256};

func private %fill_pair(v0.objref<@pair>, v1.i1, v2.i256, v3.i256) {
    block0:
        br v1 block1 block2;

    block1:
        jump block3;

    block2:
        jump block3;

    block3:
        v4.objref<@pair> = phi (v0 block1) (v0 block2);
        v5.objref<i256> = obj.proj v4 0.i8;
        obj.store v5 v2;
        v6.objref<i256> = obj.proj v4 1.i8;
        obj.store v6 v3;
        return;
}

func private %sum_pair(v0.i1, v1.i256, v2.i256) -> i256 {
    block0:
        v3.objref<@pair> = obj.alloc @pair;
        call %fill_pair v3 v0 v1 v2;
        v4.objref<i256> = obj.proj v3 0.i8;
        v5.i256 = obj.load v4;
        v6.objref<i256> = obj.proj v3 1.i8;
        v7.i256 = obj.load v6;
        v8.i256 = add v5 v7;
        return v8;
}
