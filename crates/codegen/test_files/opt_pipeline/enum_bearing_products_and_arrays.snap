source: crates/codegen/tests/opt_pipeline.rs
input_file: test_files/opt_pipeline/enum_bearing_products_and_arrays.sntn
---
target = "evm-ethereum-osaka"

type @Wrapper = {@OptionI256, i256};
type @TwoEnums = {@OptionI256, @Flag};
type @OptionI256 = enum {
    #None,
    #Some(i256),
};
type @Flag = enum {
    #Off,
    #On(i256),
};

func public %entry(v0.i256, v1.i256) -> i256 {
    block0:
        v11.@OptionI256 = enum.make @OptionI256 #Some v0;
        enum.assert_variant v11 #Some;
        v17.i256 = add v0 1.i256;
        enum.assert_variant v11 #Some;
        v27.@Flag = enum.make @Flag #On v1;
        enum.assert_variant v11 #Some;
        enum.assert_variant v27 #On;
        v34.i256 = add v0 v1;
        v5.i256 = add v17 v0;
        v6.i256 = add v5 v34;
        return v6;
}


object @Contract {
    section runtime {
        entry %entry;
    }
}
