target = "evm-ethereum-osaka"

func public %entry(v0.i256) -> i256 {
    block0:
        v1.i1 = lt v0 10.i256;
        br v1 block1 block4;

    block1:
        v2.i256 = add v0 1.i256;
        v3.i1 = lt v2 11.i256;
        br v3 block2 block3;

    block2:
        return v2;

    block3:
        return 99.i256;

    block4:
        return 100.i256;
}
