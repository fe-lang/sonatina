target = "evm-ethereum-london"

# check: block1:
# nextln:     return 1.i32;
func public %predicated_value_inference_nested_not(v0.i32) -> i32 {
    block0:
        v1.i1 = ne v0 0.i32;
        v2.i1 = not v1;
        br v2 block1 block2;

    block1:
        v3.i32 = add v0 1.i32;
        return v3;

    block2:
        return 0.i32;
}
