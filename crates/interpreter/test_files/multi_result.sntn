target = "evm-ethereum-london"

#[(254.i8, 1.i8) -> 255.i8]
#[(255.i8, 1.i8) -> 0.i8]
func private %uaddo_sum(v0.i8, v1.i8) -> i8 {
    block0:
        (v2.i8, v3.i1) = uaddo v0 v1;
        return v2;
}

#[(254.i8, 1.i8) -> 0.i1]
#[(255.i8, 1.i8) -> 1.i1]
func private %uaddo_overflow(v0.i8, v1.i8) -> i1 {
    block0:
        (v2.i8, v3.i1) = uaddo v0 v1;
        return v3;
}
